<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="metadata.universal.python" name="Universal Movie Scraper" version="0.1.0" provider-name="Olympia">
    <requires>
      <import addon="xbmc.python" version="3.0.0"/>
      <import addon="xbmc.metadata.scraper.movies" version="1.0"/>
    </requires>
    <extension point="xbmc.metadata.scraper.movies" language="en"/>
    <extension point="xbmc.python.script" library="default.py"/>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">Universal Movie Scraper (Python rewrite)</summary>
      <description lang="en">Scrapes movie metadata from multiple sources including TMDB and a local IMDb cache.</description>
      <platform>all</platform>
      <license>GPL-2.0-or-later</license>
      <source>https://github.com/olympia/kodi-repo</source>
      <website>https://github.com/olympia/kodi-repo</website>
    </extension>
  </addon>
  <addon id="repository.olympia" name="Olympia's Repository" version="1.0.0" provider-name="Olympia">
    <requires>
      <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Olympia's Repository">
      <dir>
        <info compressed="false">https://olympia.github.io/kodi-repo/addons.xml</info>
        <checksum>https://olympia.github.io/kodi-repo/addons.xml.md5</checksum>
        <datadir zip="true">https://olympia.github.io/kodi-repo</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary>Olympia's Repository</summary>
      <description>Custom Kodi addon repository by Olympia. Home of the Universal Movie Scraper.</description>
      <platform>all</platform>
    </extension>
  </addon>
</addons>
